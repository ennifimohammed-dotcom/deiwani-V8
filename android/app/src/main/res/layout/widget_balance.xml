<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#3B4A7A"
    android:padding="14dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp"
        android:background="#3B4A7A"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/w_badge_pos"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="موجب ↑"
            android:textColor="#00C896"
            android:textSize="13sp"
            android:textStyle="bold"
            android:background="#00C896"
            android:padding="6dp"/>

        <TextView
            android:id="@+id/w_badge_neg"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="سالب ↓"
            android:textColor="#FF4757"
            android:textSize="13sp"
            android:textStyle="bold"
            android:background="#FF4757"
            android:padding="6dp"
            android:visibility="gone"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/w_balance"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="0 DH"
            android:textColor="#FFFFFF"/>

        <TextView
            android:id="@+id/w_lent"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="0 DH"
            android:textColor="#00C896"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/w_borrowed"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="0 DH"
            android:textColor="#FF4757"/>

        <TextView
            android:id="@+id/w_overdue"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="0"
            android:textColor="#FFFFFF"/>
    </LinearLayout>

</LinearLayout>
